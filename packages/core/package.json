{
  "name": "@triadjs/core",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scenario-auto": {
      "types": "./dist/scenario-auto.d.ts",
      "import": "./dist/scenario-auto.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "fast-check": "^3.23.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "description": "Triad schema DSL, endpoint, channel, behavior, and router primitives",
  "license": "MIT",
  "author": "Justin Hamade",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justhamade/triadjs.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/justhamade/triadjs/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/justhamade/triadjs/issues"
  },
  "keywords": [
    "triad",
    "api",
    "typescript",
    "schema",
    "dsl",
    "validation",
    "openapi",
    "bdd",
    "testing"
  ],
  "private": false
}

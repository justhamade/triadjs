{
  "name": "@triadjs/cli",
  "version": "0.2.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "triad": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@triadjs/asyncapi": "0.2.1",
    "@triadjs/channel-client": "0.2.1",
    "@triadjs/core": "0.2.1",
    "@triadjs/forms": "0.2.1",
    "@triadjs/gherkin": "0.2.1",
    "@triadjs/openapi": "0.2.1",
    "@triadjs/solid-query": "0.2.1",
    "@triadjs/svelte-query": "0.2.1",
    "@triadjs/tanstack-query": "0.2.1",
    "@triadjs/test-runner": "0.2.1",
    "@triadjs/vue-query": "0.2.1",
    "commander": "^12.1.0",
    "jiti": "^2.4.0",
    "picocolors": "^1.1.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "description": "Triad CLI — test, docs, fuzz, validate, mock, scaffold, and frontend codegen",
  "license": "MIT",
  "author": "Justin Hamade",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justhamade/triadjs.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/justhamade/triadjs/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/justhamade/triadjs/issues"
  },
  "keywords": [
    "triad",
    "api",
    "typescript",
    "cli",
    "developer-tools",
    "codegen"
  ],
  "private": false
}

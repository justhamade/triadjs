{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@triadjs/core": ["../core/src/index.ts"],
      "@triadjs/core/scenario-auto": ["../core/src/scenario-auto.ts"],
      "@triadjs/openapi": ["../openapi/src/index.ts"],
      "@triadjs/asyncapi": ["../asyncapi/src/index.ts"],
      "@triadjs/gherkin": ["../gherkin/src/index.ts"],
      "@triadjs/tanstack-query": ["../tanstack-query/src/index.ts"],
      "@triadjs/channel-client": ["../channel-client/src/index.ts"],
      "@triadjs/solid-query": ["../solid-query/src/index.ts"],
      "@triadjs/vue-query": ["../vue-query/src/index.ts"],
      "@triadjs/svelte-query": ["../svelte-query/src/index.ts"],
      "@triadjs/forms": ["../forms/src/index.ts"],
      "@triadjs/test-runner": ["../test-runner/src/index.ts"]
    },
    "noEmit": true
  },
  "include": ["src/**/*", "__tests__/**/*"]
}

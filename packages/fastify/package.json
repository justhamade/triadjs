{
  "name": "@triadjs/fastify",
  "version": "0.2.7",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@triadjs/asyncapi": "0.2.2",
    "@triadjs/openapi": "0.2.7"
  },
  "peerDependencies": {
    "@fastify/multipart": "^9.0.0 || ^8.0.0",
    "@fastify/websocket": "^11.0.0 || ^10.0.0",
    "@triadjs/core": "0.2.2",
    "fastify": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "@fastify/multipart": {
      "optional": true
    },
    "@fastify/websocket": {
      "optional": true
    }
  },
  "devDependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/websocket": "^11.0.0",
    "@triadjs/core": "0.2.2",
    "@types/ws": "^8.18.1",
    "fastify": "^5.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "description": "Fastify HTTP and WebSocket adapter for Triad routers",
  "license": "MIT",
  "author": "Justin Hamade",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justhamade/triadjs.git",
    "directory": "packages/fastify"
  },
  "homepage": "https://github.com/justhamade/triadjs/tree/main/packages/fastify",
  "bugs": {
    "url": "https://github.com/justhamade/triadjs/issues"
  },
  "keywords": [
    "triad",
    "api",
    "typescript",
    "fastify",
    "http",
    "websocket",
    "adapter"
  ],
  "private": false
}

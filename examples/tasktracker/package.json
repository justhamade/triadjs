{
  "name": "@triadjs/example-tasktracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Triad reference example — a task-tracker API demonstrating auth, ownership, pagination, nested resources, and the @triadjs/express adapter.",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "docs": "triad docs",
    "gherkin": "triad gherkin",
    "test": "triad test",
    "test:e2e": "vitest run --config ./vitest.e2e.config.ts",
    "validate": "triad validate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@triadjs/core": "*",
    "@triadjs/drizzle": "*",
    "@triadjs/express": "*",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.36.0",
    "express": "^4.19.0"
  },
  "devDependencies": {
    "@triadjs/cli": "*",
    "@triadjs/test-runner": "*",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

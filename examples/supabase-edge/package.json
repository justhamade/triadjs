{
  "name": "@triadjs/example-supabase-edge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Triad reference example — a Supabase Edge Function API deployed on Deno via @triadjs/hono",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "docs": "triad docs",
    "gherkin": "triad gherkin",
    "test": "triad test",
    "test:e2e": "vitest run --config ./vitest.e2e.config.ts",
    "validate": "triad validate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@supabase/supabase-js": "^2.45.0",
    "@triadjs/core": "*",
    "@triadjs/hono": "*",
    "hono": "^4.10.0"
  },
  "devDependencies": {
    "@triadjs/cli": "*",
    "@triadjs/test-runner": "*",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

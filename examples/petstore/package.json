{
  "name": "@triad/example-petstore",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Triad reference example — a full petstore API using @triad/core, @triad/fastify, and the triad CLI.",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "docs": "triad docs",
    "gherkin": "triad gherkin",
    "test": "triad test",
    "test:e2e": "vitest run --config ./vitest.e2e.config.ts",
    "validate": "triad validate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.0",
    "@triad/core": "*",
    "@triad/drizzle": "*",
    "@triad/fastify": "*",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@triad/cli": "*",
    "@triad/test-runner": "*",
    "@types/better-sqlite3": "^7.6.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "ws": "^8.18.0"
  }
}
